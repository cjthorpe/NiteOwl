{
  "name": "niteowl",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo build && eslint . --ext .ts,.tsx,.js,.cjs,.mjs --max-warnings 0 && pnpm run lint:boundaries",
    "lint:boundaries": "eslint --no-eslintrc --no-inline-config -c eslint.boundaries.cjs --ext .ts,.tsx apps packages",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "spdx:check": "node scripts/spdx-headers.mjs --check",
    "spdx:write": "node scripts/spdx-headers.mjs --write",
    "spdx:test": "node --test scripts/spdx-headers.test.mjs",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.1",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  }
}
