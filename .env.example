# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# Public origin where the API is reachable from the browser. Used to build OAuth
# redirect_uri values, e.g. `${API_URL}/auth/jira/callback`, which MUST exactly
# match the Callback URL registered in each provider's OAuth app. Defaults to
# http://localhost:3001 (the API_PORT above) if unset — set it to your real
# public origin in any deployed environment. GitHub OAuth ignores this (it uses
# its app-registered callback), so a wrong value breaks only Linear/Jira.
API_URL=http://localhost:3001

# Public origin of the web app — where OAuth callbacks return the user after a
# successful connect (e.g. `${WEB_URL}/auth/callback?...`).
WEB_URL=http://localhost:5173

# ─── Web ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=niteowl
POSTGRES_USER=niteowl
POSTGRES_PASSWORD=niteowl_dev_password
DATABASE_URL=postgresql://niteowl:niteowl_dev_password@localhost:5432/niteowl

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Email (password reset) ────────────────────────────────────────────────────
# Transport for outbound mail (forgot-password flow). Default provider: Resend.
# Validated at startup in production; optional in dev/test.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Verified sender, e.g. "NiteOwl <no-reply@yourdomain.com>"
RESEND_FROM=
# Web origin used to build the reset link (falls back to CORS_ORIGIN).
APP_BASE_URL=http://localhost:5173

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Atlassian 3LO (Jira). offline_access scope is requested so a rotating refresh
# token is issued; the catch-up poller renews the access token before REST calls.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# Shared secret embedded in the Jira webhook URL (?token=…) for delivery auth.
JIRA_WEBHOOK_SECRET=

# ─── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for application-layer field encryption at rest (OAuth tokens,
# webhook URLs, config blobs). Consumed by @niteowl/db (packages/db/src/encryption.ts).
# Accepts a 32-byte key as 64 hex chars OR 44-char base64.
# Generate: openssl rand -hex 32
# ROTATE: see docs/key-rotation.md before changing this value in production.
DB_ENCRYPTION_KEY=
