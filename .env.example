# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# ─── Web ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=niteowl
POSTGRES_USER=niteowl
POSTGRES_PASSWORD=niteowl_dev_password
DATABASE_URL=postgresql://niteowl:niteowl_dev_password@localhost:5432/niteowl

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ─── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting OAuth tokens at rest.
# Must be exactly 32 random bytes expressed as 64 hex characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ROTATE: when rotating, decrypt existing rows with the old key, re-encrypt with
# the new key, then deploy the new ENCRYPTION_KEY. See docs/key-rotation.md.
ENCRYPTION_KEY=
