# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# ─── Web ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=niteowl
POSTGRES_USER=niteowl
POSTGRES_PASSWORD=niteowl_dev_password
DATABASE_URL=postgresql://niteowl:niteowl_dev_password@localhost:5432/niteowl

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Email (password reset) ────────────────────────────────────────────────────
# Transport for outbound mail (forgot-password flow). Default provider: Resend.
# Validated at startup in production; optional in dev/test.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Verified sender, e.g. "NiteOwl <no-reply@yourdomain.com>"
RESEND_FROM=
# Web origin used to build the reset link (falls back to CORS_ORIGIN).
APP_BASE_URL=http://localhost:5173

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ─── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key used by @niteowl/db for at-rest field encryption: OAuth access/
# refresh tokens (FUL-135) and Slack webhook URLs. REQUIRED in any environment
# that connects an integration — without it those writes/reads throw.
# Accepts 64 hex characters (32 bytes) or 32-byte base64.
# Generate: openssl rand -hex 32
# ROTATE: decrypt existing rows with the old key, re-encrypt with the new key,
# then deploy the new value. Backfill helper: pnpm --filter @niteowl/db
# db:backfill:oauth-encryption (idempotent; encrypts any legacy plaintext rows).
DB_ENCRYPTION_KEY=

# Legacy key for the (currently unused) @niteowl/shared token-crypto helpers.
# Field encryption uses DB_ENCRYPTION_KEY above. Tracked for consolidation.
ENCRYPTION_KEY=
