# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# ─── Web ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=niteowl
POSTGRES_USER=niteowl
POSTGRES_PASSWORD=niteowl_dev_password
DATABASE_URL=postgresql://niteowl:niteowl_dev_password@localhost:5432/niteowl

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
